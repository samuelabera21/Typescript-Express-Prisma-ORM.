# Backend
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/auth_system
JWT_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me

# Resend email setup
RESEND_API_KEY=replace_with_your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional: expose verification link/token in API responses for local debugging only
DEBUG_EMAIL_LINKS=false
