# Backend
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/auth_system
JWT_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me

# Email setup (Option A: Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_google_app_password
MAIL_FROM=your_email@gmail.com

# Email setup (Option B: Resend)
RESEND_API_KEY=replace_with_your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional: expose verification link/token in API responses for local debugging only
DEBUG_EMAIL_LINKS=false
